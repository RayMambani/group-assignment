<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BudgetQuest" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">#0A192F</item>
        <item name="android:navigationBarColor">#0A192F</item>
        <item name="android:windowBackground">@color/cyber_background</item>
    </style>

    <!-- Theme used to avoid the white flash on app startup -->
    <style name="Theme.App.Starting" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/cyber_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        
        <!-- Android 12+ Splash Screen support -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/cyber_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/ic_launcher_logo_foreground</item>
    </style>
</resources>
